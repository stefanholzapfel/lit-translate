{
  "name": "@stefanholzapfel/lit-translate",
  "version": "4.0.1",
  "description": "A lightweight translation directive for Lit",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stefanholzapfel/lit-translate.git"
  },
  "scripts": {
    "build": "rm -rf ./dist/ && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "publish_npm": "yarn test && rm -rf ./dist/ && tsc && yarn publish"
  },
  "author": "Stefan Holzapfel",
  "license": "MIT",
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "happy-dom": "^20.10.6",
    "lit": "^3.3.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./translate.js": {
      "types": "./dist/translate.directive.d.ts",
      "default": "./dist/translate.directive.js"
    },
    "./translateService.js": {
      "types": "./dist/translate.service.d.ts",
      "default": "./dist/translate.service.js"
    },
    "./translateUnsafeHTML.js": {
      "types": "./dist/translateUnsafeHTML.directive.d.ts",
      "default": "./dist/translateUnsafeHTML.directive.js"
    },
    "./translateUppercase.js": {
      "types": "./dist/translateUppercase.directive.d.ts",
      "default": "./dist/translateUppercase.directive.js"
    },
    "./translateLowercase.js": {
      "types": "./dist/translateLowercase.directive.d.ts",
      "default": "./dist/translateLowercase.directive.js"
    },
    "./translateObject.js": {
      "types": "./dist/translateObject.directive.d.ts",
      "default": "./dist/translateObject.directive.js"
    },
    "./translateObjectUnsafeHTML.js": {
      "types": "./dist/translateObjectUnsafeHTML.directive.d.ts",
      "default": "./dist/translateObjectUnsafeHTML.directive.js"
    }
  },
  "files": [
    "dist",
    "src"
  ]
}
